# === 通用 ===
DEPLOY_ENV=dev
LOG_LEVEL=INFO

# === PostgreSQL ===
POSTGRES_DB=minbook
POSTGRES_USER=minbook
POSTGRES_PASSWORD=minbook_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === NATS ===
NATS_URL=nats://nats:4222
NATS_MONITORING_URL=http://nats:8222

# === JWT / 鉴权(启动时自动生成,以下值是占位) ===
JWT_SECRET=<openssl rand -hex 32>
JWT_EXPIRY_SECONDS=31536000
SERVICE_SECRET=<openssl rand -hex 32>
ALLOW_LOOPBACK_BYPASS=true
COOKIE_SECURE=false

# === OTel ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# === Grafana ===
GRAFANA_ADMIN_PASSWORD=admin  # dev only; 生产必须改为强密码

# === LLM 成本告警阈值(可被 PUT /api/cost/thresholds 覆盖) ===
LLM_COST_ALERT_DAILY_USD=20
LLM_COST_ALERT_MONTHLY_USD=500
LLM_COST_ALERT_PER_BOOK_USD=100
LLM_COST_ALERT_SPIKE_MULTIPLIER=3

# === LLM Providers(由 llm-gateway 使用,任选一个填) ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
# ZHIPU_API_KEY=...
# MOONSHOT_API_KEY=...
# QWEN_API_KEY=...
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1  # 本地 Ollama
